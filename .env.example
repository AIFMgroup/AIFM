# Database
DATABASE_URL="postgresql://user:password@localhost:5432/aifm_dev"

# Redis (BullMQ)
REDIS_URL="redis://localhost:6379"

# Auth (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxx"
CLERK_SECRET_KEY="sk_test_xxx"
CLERK_WEBHOOK_SECRET="whsec_xxx"

# S3 / R2 (Document storage)
S3_ENDPOINT="https://xxx.r2.cloudflarestorage.com"
S3_ACCESS_KEY_ID="xxx"
S3_SECRET_ACCESS_KEY="xxx"
S3_BUCKET_NAME="aifm-evidence"
S3_REGION="auto"

# API Integrations
# Fortnox
FORTNOX_API_KEY="xxx"
FORTNOX_CLIENT_ID="xxx"

# Bank (Nordigen / TrueLayer)
NORDIGEN_SECRET_ID="xxx"
NORDIGEN_SECRET_KEY="xxx"

# Allvue
ALLVUE_API_KEY="xxx"

# Sentry
SENTRY_DSN="https://xxx.sentry.io/yyy"
NEXT_PUBLIC_SENTRY_ENVIRONMENT="development"

# OpenTelemetry (Grafana Tempo)
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"

# Email (for SLA reminders, reports)
SENDGRID_API_KEY="xxx"
SMTP_FROM="no-reply@aifm.local"

# Admin / Monitoring
ADMIN_EMAIL="admin@company.com"
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/xxx"

# Secrets management (for prod)
VAULT_ADDR="https://vault.railway.app"
VAULT_TOKEN="s.xxx"

# Next.js / API
NEXT_PUBLIC_API_URL="http://localhost:3000"
NODE_ENV="development"

# Python Workers
PYTHON_WORKERS_PORT="5000"
PYTHON_CMD="python3"

# Datia ESG API (https://docs.datia.app/)
DATIA_API_KEY="your-datia-api-key"
DATIA_API_URL="https://eco.datia.app"

# NAV Engine – DynamoDB (see scripts/NAV_DYNAMODB_ENV.md)
# FUND_REGISTRY_TABLE=aifm-fund-registry
# NAV_RECORDS_TABLE=aifm-nav-records
# NAV_APPROVALS_TABLE=aifm-nav-approvals
# NAV_RUNS_TABLE=aifm-nav-runs
# FUND_CONFIG_TABLE=aifm-fund-config
# NAV_SETTINGS_TABLE=aifm-nav-settings
# AWS_REGION=eu-north-1

# NAV – Price provider: fund_registry | lseg | csv | manual | mock
# NAV_PRICE_PROVIDER=fund_registry
# NAV_SENDER_EMAIL=nav@aifm.se
# NAV_DISTRIBUTION_EMAILS=recipient@example.com (comma-separated, gets NAV report after approval)

# LSEG / Refinitiv (pricing + referensdata) – kräver licens
# LSEG_API_KEY=your-lseg-app-key
# LSEG_API_SECRET=your-lseg-secret
# LSEG_API_URL=https://api.refinitiv.com

# SEB Custody API – positioner och kassor (developer.sebgroup.com, OAuth2 + mTLS i prod)
# SEB_CLIENT_ID=your-oauth2-client-id
# SEB_CLIENT_SECRET=your-oauth2-client-secret
# SEB_API_URL=https://api.seb.se
# SEB_USE_SANDBOX=true
# SEB_CUSTODY_ACCOUNT_ID=optional-default-account
# SEB_FUND_ACCOUNT_MAPPINGS=[{"fundId":"<registry-fund-id>","sebAccountId":"SEB-001"}]
